# ==========================================
# ARQUIVO DE EXEMPLO PARA VARIÁVEIS DE AMBIENTE
# ==========================================
# Instruções:
# 1. Copie este arquivo e renomeie a cópia para "secrets.properties"
# 2. O arquivo secrets.properties é ignorado pelo Git (veja o .gitignore) para manter suas senhas seguras.
# 3. Preencha os valores abaixo com as credenciais do seu próprio ambiente de testes.

# 1. Configurações de E-mail (SMTP)
# Utilize o seu e-mail do Gmail e gere uma "Senha de App" nas configurações da sua conta Google.
spring.mail.username=seu_email_pessoal@gmail.com
spring.mail.password=sua_senha_de_aplicativo_de_16_digitos

# 2. Segurança da API Interna
# Defina um token (senha) que o Frontend deverá enviar para autorizar a geração de certificados
API_SECRET=seu_token_super_secreto_para_testes

# 3. Credenciais da Google Drive API (OAuth 2.0)
# Obtenha isso no Google Cloud Console (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=seu_client_id_gerado_no_gcp.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret_gerado_no_gcp

# Para gerar o Refresh Token, use o OAuth 2.0 Playground:
# https://developers.google.com/oauthplayground/
# Escopo necessário: https://www.googleapis.com/auth/drive
GOOGLE_REFRESH_TOKEN=1//seu_refresh_token_gerado_no_playground

# 4. ID da Pasta de Destino no Google Drive
# Crie uma pasta vazia no seu Drive, acesse-a e copie o ID presente na URL
# Exemplo: https://drive.google.com/drive/folders/1A2B3C4D5E6F7G8H9I0J
GOOGLE_DRIVE_PASTA_RAIZ_ID=cole_aqui_apenas_o_id_da_pasta

# 5. ID da Planilha do Google Sheets para Controle
# Abra a planilha no navegador e copie o ID presente na URL
GOOGLE_SHEETS_PLANILHA_ID=cole_aqui_o_id_da_planilha